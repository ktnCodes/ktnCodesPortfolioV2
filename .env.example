GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=

# Contact email shown in the chatbot and contact section.
# Kept out of portfolio-config.json to avoid email scraping from the public repo.
NEXT_PUBLIC_CONTACT_EMAIL=

# Set to "true" to skip Google Gemini and always use OpenAI (useful when Gemini quota is exhausted on Vercel)
DISABLE_GOOGLE=
